#!/usr/bin/env bash
# project-pre-commit вЂ” Lifecycle enforcement for user projects
# Installed by init-agents.sh in the user's project.
#
# Enforces:
# 1) Tests pass (from STACK_CONFIG.md)
# 2) Build succeeds (from STACK_CONFIG.md)
# 3) No secrets committed (API keys, tokens, passwords)
# 4) No hardcoded tokens outside design system
# 5) Design gate (if visual changes: HTML, CSS, components)
#
# This hook reads commands from STACK_CONFIG.md вЂ” stack-agnostic by design.

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)

# === RUNTIME CONTROLS ===
# Configure via environment variables:
#   SKILLS_HOOK_LEVEL=minimal|standard|strict (default: standard)
#   SKILLS_DISABLED_HOOKS=tests,secrets,design (comma-separated)
#   SKILLS_TEST_TIMEOUT=60 (seconds, default: 60)

HOOK_LEVEL="${SKILLS_HOOK_LEVEL:-standard}"
DISABLED_HOOKS="${SKILLS_DISABLED_HOOKS:-}"
TEST_TIMEOUT="${SKILLS_TEST_TIMEOUT:-60}"

is_hook_enabled() {
  local hook="$1"
  echo "$DISABLED_HOOKS" | grep -q "$hook" && return 1 || return 0
}

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# === READ STACK_CONFIG.md ===
STACK_CONFIG="${REPO_ROOT}/STACK_CONFIG.md"

get_cmd() {
  local action="$1"
  if [[ -f "$STACK_CONFIG" ]]; then
    # Extract command from STACK_CONFIG.md table: | Action | `command` |
    local cmd
    cmd=$(grep -E "^\| ${action} \|" "$STACK_CONFIG" | sed 's/.*`\([^`]*\)`.*/\1/' | head -1)
    if [[ -n "$cmd" && "$cmd" != "<not detected>" && "$cmd" != "<configure:"* ]]; then
      echo "$cmd"
    fi
  fi
}

TEST_CMD=$(get_cmd "Test")
BUILD_CMD=$(get_cmd "Build")
LINT_CMD=$(get_cmd "Lint")
TYPECHECK_CMD=$(get_cmd "Type check")

echo ""
if ! bash scripts/commit-gate.sh 2>&1; then
  exit 1
fi
echo "в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—"
echo "в•‘  LIFECYCLE ENFORCEMENT                     в•‘"
echo "в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ"

# === 1. TESTS PASS ===
if is_hook_enabled "tests" && [[ -n "$TEST_CMD" ]]; then
  echo ""
  echo "  Running tests: ${GREEN}${TEST_CMD}${NC}"
  if timeout "$TEST_TIMEOUT" sh -c "$TEST_CMD" 2>&1; then
    echo "  ${GREEN}вњ“${NC} Tests pass"
  else
    echo ""
    echo "  ${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
    echo "  ${RED}в•‘  TESTS FAILED                                            в•‘${NC}"
    echo "  ${RED}в•‘                                                         в•‘${NC}"
    echo "  ${RED}в•‘  Fix failing tests before committing.                   в•‘${NC}"
    echo "  ${RED}в•‘  This is Rule 9: Verification checklist.                в•‘${NC}"
    echo "  ${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
    echo ""
    exit 1
  fi
else
  echo "  ${YELLOW}в€’${NC} No test command configured вЂ” skipped"
fi

# === 2. BUILD SUCCEEDS ===
if is_hook_enabled "build" && [[ -n "$BUILD_CMD" ]]; then
  echo ""
  echo "  Running build: ${GREEN}${BUILD_CMD}${NC}"
  if eval "$BUILD_CMD" 2>&1; then
    echo "  ${GREEN}вњ“${NC} Build succeeds"
  else
    echo ""
    echo "  ${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
    echo "  ${RED}в•‘  BUILD FAILED                                            в•‘${NC}"
    echo "  ${RED}в•‘                                                         в•‘${NC}"
    echo "  ${RED}в•‘  Fix build errors before committing.                    в•‘${NC}"
    echo "  ${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
    echo ""
    exit 1
  fi
else
  echo "  ${YELLOW}в€’${NC} No build command configured вЂ” skipped"
fi

# === 3. NO SECRETS ===
if is_hook_enabled "secrets"; then
echo ""
if ! bash scripts/commit-gate.sh 2>&1; then
  exit 1
fi
echo "  Checking for secrets..."

SECRET_PATTERNS=(
  "AKIA[0-9A-Z]{16}"           # AWS Access Key
  "sk-[0-9a-zA-Z]{32,}"        # OpenAI API key
  "ghp_[0-9a-zA-Z]{36}"        # GitHub personal access token
  "xox[baprs]-[0-9a-zA-Z-]+"   # Slack token
  "-----BEGIN.*PRIVATE KEY"     # Private key
  "password\s*=\s*[\"'][^\"']+" # Password assignment
  "secret\s*=\s*[\"'][^\"']+"   # Secret assignment
  "api[_-]?key\s*=\s*[\"'][^\"']+" # API key assignment
)

SECRETS_FOUND=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

for file in $STAGED_FILES; do
  [[ -f "$file" ]] || continue
  # Skip binary files
  case "$file" in
    *.png|*.jpg|*.jpeg|*.gif|*.svg|*.ico|*.lock|*.sum|node_modules/*) continue ;;
  esac

  for pattern in "${SECRET_PATTERNS[@]}"; do
    if grep -qE "$pattern" "$file" 2>/dev/null; then
      echo "  ${RED}вњ—${NC} $file вЂ” potential secret detected"
      SECRETS_FOUND=1
    fi
  done
done

if [[ "$SECRETS_FOUND" -eq 1 ]]; then
  echo ""
  echo "  ${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
  echo "  ${RED}в•‘  SECRETS DETECTED                                        в•‘${NC}"
  echo "  ${RED}в•‘                                                         в•‘${NC}"
  echo "  ${RED}в•‘  Remove secrets before committing.                      в•‘${NC}"
  echo "  ${RED}в•‘  Use .env + .gitignore instead of hardcoding.           в•‘${NC}"
  echo "  ${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
  echo ""
  exit 1
else
  echo "  ${GREEN}вњ“${NC} No secrets detected"
fi
fi

# === 4. DESIGN GATE (if visual changes) ===
VISUAL_CHANGES=$(echo "$STAGED_FILES" | grep -E '\.(html|css|scss|less|jsx|tsx|vue|svelte)$' 2>/dev/null || true)
if [[ -n "$VISUAL_CHANGES" ]]; then
  echo ""
  echo "  ${YELLOW}вљ ${NC} Visual changes detected"
  if [[ -f "${REPO_ROOT}/DESIGN.md" ]] || [[ -f "${REPO_ROOT}/design/DESIGN-LOCK.md" ]]; then
    echo "  ${GREEN}вњ“${NC} Design doc exists"
  else
    echo "  ${YELLOW}вљ ${NC} No DESIGN.md found. Consider documenting design decisions."
    echo "  This is not blocked but is tracked."
  fi
fi

echo ""
if ! bash scripts/commit-gate.sh 2>&1; then
  exit 1
fi
echo "  ${GREEN}вњ“${NC} All lifecycle checks passed"
echo ""
if ! bash scripts/commit-gate.sh 2>&1; then
  exit 1
fi
exit 0
